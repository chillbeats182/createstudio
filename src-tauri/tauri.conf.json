{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/dev/tooling/cli/schema.json",
  "productName": "OreateAI Studio",
  "version": "0.2.0",
  "identifier": "com.createstudio.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "OreateAI Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "http": {
      "scope": [
        "https://www.oreateai.com/**",
        "https://storage.googleapis.com/**"
      ]
    }
  }
}