{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri/dev/crates/tauri-utils/schema.json",
  "identifier": "default",
  "description": "Default capability for OreateAI Studio",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://www.oreateai.com/**" },
        { "url": "https://storage.googleapis.com/**" }
      ]
    },
    "shell:allow-open"
  ]
}