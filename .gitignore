# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
server.log
test
prompt

# Skills directory
/skills/

# Tauri build artifacts
src-tauri/target/

# Temp/working files (project root only)
/captured-js/
/tool-results/
/upload/
/download/
/oreateai-video-tool/
/dashboard-screenshot.png
/dashboard-final.png
/screenshot-*.png

# Root-level data files (not configs)
/*.json
!/.github/**/*.json
/*.txt
/*.mp4
/*.html

# But KEEP these root configs
!/package.json
!/tsconfig.json
!/tailwind.config.ts
!/components.json
!/postcss.config.mjs
!/next.config.ts
!/eslint.config.mjs
!/Caddyfile